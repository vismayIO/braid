{
  "author": "Vismay Patel",
  "bin": {
    "braid": "./dist/cli.js"
  },
  "bugs": {
    "url": "https://github.com/vismayIO/braid/issues"
  },
  "description": "Multi-provider AI agent orchestrator that dispatches one task to Codex, Gemini, and Ollama in parallel, shares context through a memory layer, and merges their outputs.",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/vismayIO/braid#readme",
  "keywords": [
    "ai",
    "llm",
    "agent",
    "orchestrator",
    "cli",
    "bun",
    "typescript",
    "codex",
    "gemini",
    "ollama",
    "multi-agent"
  ],
  "license": "MIT",
  "name": "braid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vismayIO/braid.git"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "check": "biome check .",
    "check:changed": "biome check --changed --since=origin/main --no-errors-on-unmatched",
    "check:ci": "biome ci --reporter=github .",
    "check:fix": "biome check --write .",
    "check:staged": "biome check --staged --write --no-errors-on-unmatched",
    "check:unsafe": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:unsafe": "biome lint --write --unsafe .",
    "test": "bun test",
    "test:e2e": "RUN_E2E=1 bun test tests/e2e/",
    "test:integration": "bun test tests/integration/*.test.ts",
    "test:unit": "bun test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "bun run check:ci && bun run typecheck && bun run test"
  },
  "type": "module",
  "version": "0.1.0"
}
